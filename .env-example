# ============================================
# Banco de Talentos - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# Segurança
SECRET_KEY=django-insecure-GERE-UMA-CHAVE-SEGURA
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Banco de dados
POSTGRES_DB=bancodetalentos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=suasenha
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Admin Django
DJANGO_ADMIN_EMAIL=admin@admin.com
DJANGO_ADMIN_PASSWORD=suasenha

# CORS e CSRF (separar por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3025,http://127.0.0.1:3000,http://127.0.0.1:3025
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3025,http://127.0.0.1:3000,http://127.0.0.1:3025

# E-mail SMTP
EMAIL_HOST=mail.tesseratointegra.com.br
EMAIL_HOST_USER=seuemail@email.com
EMAIL_HOST_PASSWORD=suasenha

# Frontend (para reset de senha e integração)
FRONTEND_URL=http://localhost:3025

# AWS S3 (Storage de arquivos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://bancodetalentos_evolution:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=bancodetalentos

# OpenAI (para insights do dashboard)
OPENAI_API_KEY=
